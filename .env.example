# RossBot environment template — copy to .env and fill locally. NEVER commit real secrets.
# Only infra/connection + bootstrap flags live here; all STRATEGY ⚠️CONFLICT values (C1–C16)
# live in the `config` DB table, not in env (STANDING RULES B).

# --- Database (matches docker-compose.yml) ---
ROSSBOT_DATABASE_URL=postgresql+psycopg://rossbot:rossbot@localhost:5432/rossbot

# --- Redis (hot state / pub-sub) ---
ROSSBOT_REDIS_URL=redis://localhost:6379/0

# --- Runtime ---
ROSSBOT_ENV=development          # development | sim | paper | live
ROSSBOT_LOG_LEVEL=INFO
ROSSBOT_LOG_JSON=true

# --- Clock-drift guard (NTP) ---
ROSSBOT_NTP_SERVER=pool.ntp.org
ROSSBOT_MAX_CLOCK_DRIFT_MS=250   # fail-safe: above this, do not trade

# --- Broker / data vendor credentials (OPEN client decision #1 — left blank in Phase 0) ---
# No adapter is wired to a real vendor yet; these are placeholders for Phase 1+.
ROSSBOT_BROKER_API_KEY=
ROSSBOT_BROKER_API_SECRET=
ROSSBOT_DATA_API_KEY=

# --- Test-only: point integration tests at a throwaway Postgres (optional) ---
# ROSSBOT_TEST_DATABASE_URL=postgresql+psycopg://rossbot:rossbot@localhost:5432/rossbot_test
