# RossBot environment template — copy to .env and fill locally. NEVER commit real secrets.
# Only infra/connection + bootstrap flags live here; all STRATEGY ⚠️CONFLICT values (C1–C16)
# live in the `config` DB table, not in env (STANDING RULES B).

# ============================================================================
# Database (Supabase — hosted PostgreSQL; no local Docker/Postgres needed)
# ============================================================================
# Supabase → Project Settings → Database → Connection string → URI.
# The codebase uses the psycopg 3 driver, so prefix the host with `postgresql+psycopg://`.
# SSL is added automatically (sslmode=require) for any *.supabase.co / *.supabase.com host.
ROSSBOT_DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# If you paste Supabase's raw URI verbatim (it starts with `postgresql://`, no +psycopg),
# SQLAlchemy falls back to the psycopg2 driver — that also works because psycopg2-binary is
# in requirements.txt. Either form is fine; the +psycopg form is preferred (matches the app).
#
# Test-only: point integration tests (tests/test_schema_migration.py) at a THROWAWAY DB.
# Do NOT point this at your real Supabase project — the tests drop/recreate the schema.
# ROSSBOT_TEST_DATABASE_URL=postgresql+psycopg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================================================
# Redis (hot state / pub-sub) — Upstash (hosted; replaces the archived docker Redis)
# ============================================================================
# Upstash → create database → "Connect" → copy the redis-py / TCP credentials.
# Upstash forces TLS, so the scheme is rediss:// (two s) on port 6379. The password is the
# database token. Verify with: python scripts/check_redis.py
ROSSBOT_REDIS_URL=rediss://default:[YOUR-UPSTASH-PASSWORD]@[YOUR-ENDPOINT].upstash.io:6379

# ============================================================================
# Runtime
# ============================================================================
ROSSBOT_ENV=development          # development | sim | paper | live
ROSSBOT_LOG_LEVEL=INFO
ROSSBOT_LOG_JSON=true

# ============================================================================
# Clock-drift guard (NTP)
# ============================================================================
ROSSBOT_NTP_SERVER=pool.ntp.org
ROSSBOT_MAX_CLOCK_DRIFT_MS=250   # fail-safe: above this, do not trade

# ============================================================================
# Dashboard API (api/) — Phase 5
# ============================================================================
DASHBOARD_API_KEY=               # required to call dashboard endpoints (api/auth.py)
DASHBOARD_ORIGIN=http://localhost:3000   # CORS allow-origin for the Next.js dashboard

# ============================================================================
# Health monitor tuning (api/services/health_service.py) — optional, have defaults
# ============================================================================
# FEED_STALE_SECONDS=30
# CLOCK_DRIFT_WARN_MS=500
# NTP_SERVER=pool.ntp.org
# HEALTH_POLL_SECONDS=15

# ============================================================================
# Alerting (api/services/alert_service.py) — Phase 5, all optional
# ============================================================================
# SLACK_WEBHOOK_URL=
# ALERT_EMAIL_TO=                 # comma-separated recipients
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=rossbot@localhost
# SMTP_TLS=true

# ============================================================================
# Broker / market-data vendor credentials (Phase 1+; blank in Phase 0)
# ============================================================================
# Generic placeholders consumed by the adapter-wiring layer:
ROSSBOT_BROKER_API_KEY=
ROSSBOT_BROKER_API_SECRET=
ROSSBOT_DATA_API_KEY=
#
# Alpaca (adapters/alpaca.py, adapters/alpaca_broker.py) — keys are passed to the adapter
# constructors by the wiring layer; set them here and wire through in Phase 1.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
#
# Databento (adapters/databento.py) — the SDK reads DATABENTO_API_KEY directly from env.
DATABENTO_API_KEY=
#
# Benzinga news feed (adapters/catalyst/benzinga_feed.py) — Phase 7.
BENZINGA_API_KEY=
#
# Anthropic / Claude LLM catalyst classifier (adapters/catalyst/llm_classifier.py) — Phase 7.
ANTHROPIC_API_KEY=
#
# ── Dashboard AI Analysis — extra model providers (adapters/llm_providers.py) ──
# The "AI Analysis" page lets the operator pick a provider + model. Set any of
# these to enable that provider in the picker (all optional; Anthropic above is
# the default). Each uses the OpenAI-compatible chat endpoint.
#
# OpenAI (GPT-5.5 / GPT-5 / GPT-5-mini …) — platform.openai.com
OPENAI_API_KEY=
# NVIDIA NIM (FREE tier — DeepSeek V4 Pro, GLM-5.1, Kimi K2.6, Nemotron 3 Ultra,
# MiniMax M3, Mistral Medium 3.5…) — get an 'nvapi-...' key at build.nvidia.com
# (100+ models, OpenAI-compatible). NOTE: after editing .env, RESTART the API —
# `uvicorn --reload` only reloads .py files, not env changes.
NVIDIA_API_KEY=
# Google Gemini (Gemini 3.5 Flash / 2.5 Pro …) — aistudio.google.com
# (GOOGLE_API_KEY is also accepted as an alias.)
GEMINI_API_KEY=
